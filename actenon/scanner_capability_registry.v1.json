{
  "registry_version": "capability_registry.v1",
  "detector_categories": [
    "BROWSER_AGENT_SIDE_EFFECT",
    "COMPUTER_USE_AGENT_SIDE_EFFECT",
    "CODING_AGENT_SIDE_EFFECT",
    "SHELL_EXECUTION_SIDE_EFFECT",
    "FILE_MUTATION_SIDE_EFFECT",
    "DATABASE_MUTATION_SIDE_EFFECT",
    "CLOUD_INFRASTRUCTURE_SIDE_EFFECT",
    "EXTERNAL_API_SIDE_EFFECT",
    "MCP_TOOL_SIDE_EFFECT",
    "WORKFLOW_AUTOMATION_SIDE_EFFECT",
    "CREDENTIAL_AUTHORITY_SIGNAL",
    "AGENT_TOOL_REGISTRY_SIGNAL"
  ],
  "path_types": [
    "runtime agent loop",
    "tool handler",
    "action registry",
    "browser controller",
    "desktop controller",
    "API endpoint",
    "webhook handler",
    "background worker",
    "workflow executor",
    "CLI command",
    "integration connector",
    "database migration",
    "test",
    "example",
    "documentation",
    "config",
    "generated file"
  ],
  "surfaces": [
    {
      "surface_id": "S1",
      "name": "DATA_AND_STORAGE_MUTATION",
      "side_effect_type": "persistent data or storage mutation",
      "signal_patterns": ["\\binsert\\b", "\\bupdate\\b", "\\bdelete\\b", "\\bupsert\\b", "\\btruncate\\b", "\\balter\\s+table\\b", "\\bdrop\\s+(table|database)\\b", "\\bmigration\\.apply\\b", "\\bobject_storage\\.(put|delete)\\b", "\\bwrite_text\\(", "\\bunlink\\(", "\\brmtree\\(", "\\bpurge\\b"],
      "import_patterns": ["sqlalchemy", "psycopg", "boto3", "redis", "pymongo", "prisma"],
      "call_patterns": ["\\.insert\\(", "\\.update\\(", "\\.delete\\(", "\\.upsert\\(", "\\.execute\\([^\\n]*(DELETE|UPDATE|INSERT|ALTER|DROP|TRUNCATE)", "delete_database\\(", "delete_bucket\\(", "restore_backup\\("],
      "path_patterns": ["migrations/", "repositories/", "storage/"],
      "verb_object_hints": ["delete database", "drop table", "write file", "purge cache"],
      "base_severity": "high",
      "recommended_actenon_controls": ["PreflightEngine", "ProtectedExecutor", "CredentialBroker", "Receipt/Refusal", "replay protection"],
      "remediation": "Put persistent data/storage mutation behind a proof-gated protected endpoint, Preflight policy, credential broker, replay/idempotency guard, and Receipt/Refusal emission.",
      "caveats": "Static detection cannot prove the write reaches production data."
    },
    {
      "surface_id": "S2",
      "name": "INFRASTRUCTURE_AND_COMPUTE_CONTROL",
      "side_effect_type": "infrastructure or compute control",
      "signal_patterns": ["terraform\\s+(apply|destroy)", "pulumi\\s+(up|destroy)", "kubectl\\s+(apply|delete|scale)", "helm\\s+(install|upgrade|delete)", "docker\\s+(run|push|rm)", "\\bserverless\\s+(deploy|remove)", "\\bdeploy\\b", "\\brestart\\b", "\\bshutdown\\b", "\\bcloudfront\\b", "\\bdns\\b", "\\bfirewall\\b"],
      "import_patterns": ["kubernetes", "pulumi", "boto3", "google.cloud", "azure"],
      "call_patterns": ["create_stack\\(", "delete_stack\\(", "run_instances\\(", "terminate_instances\\(", "create_deployment\\(", "delete_namespaced"],
      "path_patterns": ["infra/", "terraform/", ".github/workflows/", "deploy/"],
      "verb_object_hints": ["destroy cluster", "delete deployment", "apply infrastructure"],
      "base_severity": "critical_candidate",
      "recommended_actenon_controls": ["ActionIntent/PCCB proof gate", "PreflightEngine", "CredentialBroker", "human approval", "Receipt/Refusal"],
      "remediation": "Require proof-bound execution, approval/evidence policy, brokered cloud authority, and receipted outcomes before infrastructure changes.",
      "caveats": "Static analysis cannot prove the command executes or targets production."
    },
    {
      "surface_id": "S3",
      "name": "IDENTITY_ACCESS_AND_SECRETS",
      "side_effect_type": "identity, access, or secret mutation",
      "signal_patterns": ["\\bgrant\\b", "\\brevoke\\b", "\\badmin\\b", "\\bcreate_api_key\\b", "\\btoken\\b", "\\bpassword_reset\\b", "\\bmfa\\b", "\\bsso\\b", "\\bservice_account\\b", "\\boauth\\b", "\\bshare\\b", "\\bsecret_manager\\b", "\\bsecretsmanager\\b"],
      "import_patterns": ["auth0", "okta", "google.oauth", "boto3", "keyring"],
      "call_patterns": ["grant_.*\\(", "revoke_.*\\(", "create_.*key\\(", "reset_password\\(", "add_user_to_group\\(", "create_service_account\\(", "keyring\\.get_password\\(", "secretsmanager"],
      "path_patterns": ["auth/", "iam/", "identity/", "secrets/"],
      "verb_object_hints": ["grant admin", "create api key", "rotate secret"],
      "base_severity": "critical_candidate",
      "recommended_actenon_controls": ["CredentialBroker", "PreflightEngine", "ActionIntent/PCCB proof gate", "Receipt/Refusal", "audit log"],
      "remediation": "Broker identity/secret authority and require proof, policy, human approval where needed, and Receipt/Refusal emission.",
      "caveats": "Bare words like token or api_key in type declarations may be non-runtime metadata."
    },
    {
      "surface_id": "S4",
      "name": "MONEY_AND_FINANCE",
      "side_effect_type": "money movement or financial commitment",
      "signal_patterns": ["\\bpayment\\b", "\\brefund\\b", "\\btransfer\\b", "\\bpayout\\b", "\\btrade\\b", "\\border\\b", "\\bcrypto\\b", "\\bsmart.?contract\\b", "\\binvoice\\s+approval\\b", "\\bpayroll\\b", "\\bsubscription\\b", "\\bbilling\\b", "\\bbank_detail\\b", "\\bpurchase\\b", "\\bprice\\b", "\\btax\\b"],
      "import_patterns": ["stripe", "plaid", "adyen", "paypal", "web3", "ethers", "shopify"],
      "call_patterns": ["PaymentIntent\\.create", "refunds\\.create", "transfers\\.create", "payouts\\.create", "approve_invoice\\(", "release_payment\\(", "submit_order\\(", "create_charge\\("],
      "path_patterns": ["payments/", "billing/", "finance/", "invoices/"],
      "verb_object_hints": ["release payment", "approve invoice", "create refund"],
      "base_severity": "critical_candidate",
      "recommended_actenon_controls": ["PreflightEngine", "human approval/evidence", "CredentialBroker", "ActionIntent/PCCB proof gate", "Receipt/Refusal"],
      "remediation": "Put financial action behind proof-bound execution, approval/evidence policy, brokered payment authority, idempotency, and Receipt/Refusal.",
      "caveats": "Static detection cannot prove funds move or an order is final."
    },
    {
      "surface_id": "S5",
      "name": "OUTBOUND_COMMUNICATION_AND_PUBLICATION",
      "side_effect_type": "external communication or publication",
      "signal_patterns": ["send_email", "send_sms", "whatsapp", "slack", "teams", "discord", "voice_call", "push_notification", "customer_notification", "support_reply", "social_post", "calendar_invite", "publish", "comment", "review", "send_message", "post_message", "chat_postMessage"],
      "import_patterns": ["sendgrid", "twilio", "slack_sdk", "discord", "mailgun"],
      "call_patterns": ["\\.send\\(", "messages\\.create\\(", "chat_postMessage\\(", "send_mail\\(", "publish\\(", "create_event\\("],
      "path_patterns": ["notifications/", "messaging/", "comms/", "support/"],
      "verb_object_hints": ["send email", "publish content", "support reply"],
      "base_severity": "high",
      "recommended_actenon_controls": ["PreflightEngine", "approval policy", "Receipt/Refusal", "audit log"],
      "remediation": "Gate outbound communications with policy/approval where needed and emit Receipt/Refusal for external messages.",
      "caveats": "Static detection cannot prove a message is delivered."
    },
    {
      "surface_id": "S6",
      "name": "BROWSER_AND_COMPUTER_USE",
      "side_effect_type": "browser or computer-use action",
      "signal_patterns": ["playwright", "selenium", "puppeteer", "browser-use", "browser_use", "stagehand", "browserbase", "skyvern", "chromium", "browser_context", "pyautogui", "computer_use", "desktop", "VNC", "noVNC", "xdotool", "remote_desktop", "captcha"],
      "import_patterns": ["playwright", "selenium", "pyautogui", "browser_use", "stagehand", "puppeteer", "xdotool"],
      "call_patterns": ["page\\.goto\\(", "\\.goto\\(", "page\\.click\\(", "locator\\([^\\n]*\\)\\.click\\(", "\\.click\\(", "page\\.fill\\(", "locator\\([^\\n]*\\)\\.fill\\(", "\\.fill\\(", "page\\.press\\(", "keyboard\\.", "mouse\\.", "page\\.evaluate\\(", "submit\\(", "upload_file\\(", "download\\(", "storage_state\\(", "cookies?", "screenshot\\(", "pyautogui\\.", "open_application\\("],
      "path_patterns": ["browser/", "rpa/", "computer_use/"],
      "verb_object_hints": ["click", "fill", "submit form", "login"],
      "base_severity": "high",
      "recommended_actenon_controls": ["ActionIntent/PCCB proof gate", "PreflightEngine", "CredentialBroker for authenticated portals", "Receipt/Refusal"],
      "remediation": "Require proof and policy before authenticated browser actions, especially clicks/fills/submits in third-party portals.",
      "caveats": "Navigation-only browser context is lower severity than authenticated mutation."
    },
    {
      "surface_id": "S7",
      "name": "CODE_AND_SOFTWARE_SUPPLY_CHAIN",
      "side_effect_type": "code or software supply-chain mutation",
      "signal_patterns": ["git\\s+(commit|push|merge)", "pull_request", "merge_pr", "npm\\s+publish", "twine\\s+upload", "docker\\s+push", "eval\\(", "exec\\(", "subprocess\\.", "os\\.system\\(", "shell=True", "generated code"],
      "import_patterns": ["subprocess", "git", "github", "gitlab"],
      "call_patterns": ["subprocess\\.run\\(", "os\\.system\\(", "eval\\(", "exec\\(", "create_pull_request\\(", "merge_pull_request\\(", "publish_package\\("],
      "path_patterns": ["release/", "ci/", "scripts/"],
      "verb_object_hints": ["publish package", "push image", "merge pull request"],
      "base_severity": "high",
      "recommended_actenon_controls": ["PreflightEngine", "approval gate", "Receipt/Refusal", "audit log", "dry-run"],
      "remediation": "Gate supply-chain actions with proof/policy, human approval where appropriate, dry-run, and receipted outcomes.",
      "caveats": "Static detection cannot prove generated code is applied."
    },
    {
      "surface_id": "S8",
      "name": "EXTERNAL_API_AND_THIRD_PARTY_MUTATION",
      "side_effect_type": "external API or SaaS mutation",
      "signal_patterns": ["data\\.export", "customer\\.export", "bulk_?export", "requests\\.(post|put|patch|delete)", "fetch\\([^\\n]*(POST|PUT|PATCH|DELETE)", "axios\\.(post|put|patch|delete)", "graphql.*mutation", "webhook", "queue\\.publish", "event\\.emit", "salesforce", "jira", "linear", "netsuite", "shopify", "hubspot", "servicenow"],
      "import_patterns": ["requests", "httpx", "axios", "salesforce", "jira", "linear", "hubspot", "servicenow"],
      "call_patterns": ["\\.post\\(", "\\.put\\(", "\\.patch\\(", "\\.delete\\(", "mutate\\(", "publish\\(", "emit\\(", "send_webhook\\("],
      "path_patterns": ["integrations/", "webhooks/", "clients/"],
      "verb_object_hints": ["post webhook", "create ticket", "update CRM"],
      "base_severity": "high",
      "recommended_actenon_controls": ["ActionIntent/PCCB proof gate", "CredentialBroker", "Receipt/Refusal", "idempotency"],
      "remediation": "Gate third-party mutations with proof, brokered credentials, idempotency/replay protection, and Receipt/Refusal.",
      "caveats": "Static detection cannot prove the remote endpoint mutates state."
    },
    {
      "surface_id": "S9",
      "name": "PHYSICAL_CYBER_PHYSICAL_IOT_ROBOTICS",
      "side_effect_type": "physical or cyber-physical actuation",
      "signal_patterns": ["unlock", "lock_door", "open_gate", "start_machine", "stop_machine", "robot", "drone", "vehicle", "building_access", "alarm", "hvac", "fleet", "scada", "manufacturing", "medical_device"],
      "import_patterns": ["rospy", "pymodbus", "homeassistant", "dronekit"],
      "call_patterns": ["unlock_.*\\(", "start_.*\\(", "stop_.*\\(", "dispatch_vehicle\\(", "set_hvac\\(", "write_register\\("],
      "path_patterns": ["iot/", "robot/", "fleet/", "facility/"],
      "verb_object_hints": ["unlock door", "start machine", "dispatch vehicle"],
      "base_severity": "critical_candidate",
      "recommended_actenon_controls": ["ActionIntent/PCCB proof gate", "PreflightEngine", "human approval", "CredentialBroker", "Receipt/Refusal"],
      "remediation": "Require proof, policy, and operator approval before physical actuation; emit Receipt/Refusal for every attempt.",
      "caveats": "Static detection cannot prove physical actuation occurred."
    },
    {
      "surface_id": "S10",
      "name": "AGENT_ORCHESTRATION_AND_DELEGATION",
      "side_effect_type": "agent delegation or tool orchestration",
      "signal_patterns": ["spawn_agent", "sub_agent", "A2A", "mcp", "available_tools", "execute_tool", "run_tool", "invoke_tool", "autonomous workflow", "scheduled agent", "background task", "memory_write", "policy update"],
      "import_patterns": ["langchain", "llamaindex", "autogen", "crewai", "semantic_kernel", "openai", "anthropic", "mcp"],
      "call_patterns": ["execute_tool\\(", "run_tool\\(", "invoke_tool\\(", "agent\\.run\\(", "crew\\.kickoff\\(", "planner\\.", "create_task\\("],
      "path_patterns": ["agents/", "workflows/", "tools/"],
      "verb_object_hints": ["delegate tool", "spawn agent", "schedule task"],
      "base_severity": "medium",
      "recommended_actenon_controls": ["Proof gate at tool boundary", "PreflightEngine", "Receipt/Refusal", "tool-call audience binding"],
      "remediation": "Require proof at delegated tool boundaries and receipt every consequential delegated action.",
      "caveats": "Agent context alone is not a side effect; severity rises when coupled to a primitive."
    },
    {
      "surface_id": "S11",
      "name": "MODEL_MEMORY_AND_KNOWLEDGE_BASE",
      "side_effect_type": "model memory or knowledge-base mutation",
      "signal_patterns": ["long_term_memory", "delete_memory", "vector", "embedding", "upsert_documents", "retrieval_source", "system_prompt", "policy_prompt", "tool_instructions", "fine_tuning", "training_job", "model_deployment"],
      "import_patterns": ["pinecone", "chromadb", "weaviate", "faiss", "qdrant", "langchain.vectorstores"],
      "call_patterns": ["add_documents\\(", "upsert\\(", "delete_collection\\(", "update_prompt\\(", "fine_tuning\\.jobs\\.create", "deploy_model\\("],
      "path_patterns": ["memory/", "rag/", "knowledge/"],
      "verb_object_hints": ["write memory", "ingest vector", "update prompt"],
      "base_severity": "medium",
      "recommended_actenon_controls": ["PreflightEngine", "evidence requirement", "Receipt/Refusal", "audit log"],
      "remediation": "Gate long-term memory and knowledge-base mutations with policy, evidence, and receipted outcomes.",
      "caveats": "Static detection cannot determine sensitivity of ingested data."
    },
    {
      "surface_id": "S12",
      "name": "LEGAL_CONTRACTUAL_AND_CONSENT",
      "side_effect_type": "legal, contractual, or consent action",
      "signal_patterns": ["docusign", "signature", "accept_terms", "consent", "legal filing", "regulatory filing", "contract_commitment", "contract_acceptance", "binding acceptance", "submit_filing"],
      "import_patterns": ["docusign", "hellosign", "adobesign"],
      "call_patterns": ["create_envelope\\(", "send_envelope\\(", "accept_terms\\(", "submit_filing\\(", "withdraw_consent\\("],
      "path_patterns": ["legal/", "contracts/", "compliance/"],
      "verb_object_hints": ["accept terms", "submit filing", "send signature"],
      "base_severity": "critical_candidate",
      "recommended_actenon_controls": ["human approval", "PreflightEngine", "ActionIntent/PCCB proof gate", "Receipt/Refusal"],
      "remediation": "Require explicit proof, approval, and evidence before contractual or consent-changing actions.",
      "caveats": "Static detection cannot prove legal effect."
    },
    {
      "surface_id": "S13",
      "name": "GOVERNANCE_ADMIN_AND_OPERATIONAL_POLICY",
      "side_effect_type": "governance or operational policy mutation",
      "signal_patterns": ["account_setting", "plan_change", "subscription_change", "data_retention", "compliance_config", "disable_approval", "override", "threshold", "policy_suppression", "alert_suppression"],
      "import_patterns": ["\\bimport\\s+admin\\b", "\\bimport\\s+policy\\b", "\\bfrom\\s+admin\\b", "\\bfrom\\s+policy\\b"],
      "call_patterns": ["update_settings\\(", "disable_.*approval\\(", "set_threshold\\(", "suppress_alert\\(", "update_policy\\("],
      "path_patterns": ["admin/", "governance/", "policy/"],
      "verb_object_hints": ["disable approval", "change retention", "suppress alert"],
      "base_severity": "high",
      "recommended_actenon_controls": ["PreflightEngine", "human approval", "Receipt/Refusal", "audit log"],
      "remediation": "Gate governance and policy mutations with proof, approval, audit, and Receipt/Refusal.",
      "caveats": "Static detection cannot prove the setting is active in production."
    },
    {
      "surface_id": "S14",
      "name": "OPERATIONAL_WORKFLOW_AND_DISPATCH",
      "side_effect_type": "operational workflow or dispatch action",
      "signal_patterns": ["dispatch", "assign_driver", "assign_case", "assign_ticket", "route_task", "priority", "sla", "escalation", "fulfillment", "delivery_timing", "approve_application", "schedule_appointment", "cancel_booking", "cancel_order", "cancel_account"],
      "import_patterns": ["zendesk", "servicenow", "jira", "linear"],
      "call_patterns": ["assign_.*\\(", "dispatch_.*\\(", "change_priority\\(", "schedule_.*\\(", "cancel_.*\\(", "approve_application\\("],
      "path_patterns": ["dispatch/", "workflow/", "operations/"],
      "verb_object_hints": ["dispatch driver", "assign ticket", "cancel booking"],
      "base_severity": "high",
      "recommended_actenon_controls": ["PreflightEngine", "Receipt/Refusal", "human override", "audit log"],
      "remediation": "Gate operational workflow changes with policy, human override where needed, and receipted outcomes.",
      "caveats": "Static detection cannot prove customer impact."
    },
    {
      "surface_id": "S15",
      "name": "REGULATED_DECISIONING",
      "side_effect_type": "regulated decision or record action",
      "signal_patterns": ["patient_record", "prescription", "referral", "student_record", "safeguarding", "benefits", "claims", "eligibility", "credit_decision", "risk_decision", "hiring_decision", "public_sector"],
      "import_patterns": ["fhir", "epic", "canvas", "blackboard"],
      "call_patterns": ["update_patient\\(", "create_prescription\\(", "decide_eligibility\\(", "approve_claim\\(", "reject_claim\\(", "credit_decision\\("],
      "path_patterns": ["health/", "education/", "claims/", "eligibility/"],
      "verb_object_hints": ["update patient", "approve claim", "decide eligibility"],
      "base_severity": "critical_candidate",
      "recommended_actenon_controls": ["PreflightEngine", "human approval/evidence", "ActionIntent/PCCB proof gate", "Receipt/Refusal", "audit log"],
      "remediation": "Require proof, policy, evidence, and human review before regulated decisioning or record updates.",
      "caveats": "Static detection cannot prove regulatory status or final decisioning."
    }
  ]
}
