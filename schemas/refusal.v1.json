{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:protected-execution:contracts:refusal:v1",
  "title": "Refusal v1",
  "description": "Structured, machine-readable refusal envelope for denied or invalid consequential-action requests.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "refusal_id",
    "category",
    "message",
    "retryable",
    "refused_at"
  ],
  "properties": {
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "const": "refusal"
        },
        "version": {
          "const": "v1"
        }
      }
    },
    "refusal_id": {
      "$ref": "#/$defs/identifier"
    },
    "intent_id": {
      "$ref": "#/$defs/identifier"
    },
    "category": {
      "type": "string",
      "enum": [
        "schema",
        "policy",
        "proof",
        "escrow",
        "replay",
        "approval",
        "evidence",
        "execution",
        "authorization",
        "system"
      ]
    },
    "reason_code": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[A-Z][A-Z0-9_:-]{2,127}$"
    },
    "refusal_code": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[A-Z][A-Z0-9_:-]{2,127}$",
      "deprecated": true
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "retryable": {
      "type": "boolean"
    },
    "refused_at": {
      "$ref": "#/$defs/timestamp"
    },
    "tenant": {
      "$ref": "#/$defs/tenant_ref"
    },
    "subject": {
      "$ref": "#/$defs/party_ref"
    },
    "audience": {
      "$ref": "#/$defs/audience_ref"
    },
    "action": {
      "$ref": "#/$defs/action_ref"
    },
    "target": {
      "$ref": "#/$defs/target_ref"
    },
    "correlation": {
      "$ref": "#/$defs/correlation_ref"
    },
    "rule_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      },
      "uniqueItems": true,
      "maxItems": 64
    },
    "violations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/violation_ref"
      },
      "maxItems": 128
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "oneOf": [
    {
      "required": [
        "reason_code"
      ]
    },
    {
      "required": [
        "refusal_code"
      ]
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id"
      ],
      "properties": {
        "tenant_id": {
          "$ref": "#/$defs/identifier"
        },
        "attributes": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "party_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 2,
          "maxLength": 64
        },
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "attributes": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "audience_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 2,
          "maxLength": 64
        },
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "uri": {
          "type": "string",
          "format": "uri-reference",
          "maxLength": 2048
        }
      }
    },
    "action_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "capability",
        "parameters"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128,
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "capability": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128,
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "target_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resource_type",
        "resource_id"
      ],
      "properties": {
        "resource_type": {
          "type": "string",
          "minLength": 2,
          "maxLength": 128
        },
        "resource_id": {
          "$ref": "#/$defs/identifier"
        },
        "uri": {
          "type": "string",
          "format": "uri-reference",
          "maxLength": 2048
        },
        "selectors": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "correlation_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pccb_id": {
          "$ref": "#/$defs/identifier"
        },
        "escrow_id": {
          "$ref": "#/$defs/identifier"
        },
        "receipt_id": {
          "$ref": "#/$defs/identifier"
        },
        "request_id": {
          "$ref": "#/$defs/identifier"
        },
        "action_hash": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "algorithm",
            "canonicalization",
            "value"
          ],
          "properties": {
            "algorithm": {
              "const": "sha-256"
            },
            "canonicalization": {
              "const": "RFC8785-JCS"
            },
            "value": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          }
        }
      }
    },
    "violation_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 2,
          "maxLength": 128
        },
        "field_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "expected": {
          "type": [
            "string",
            "number",
            "integer",
            "boolean",
            "null"
          ]
        },
        "observed": {
          "type": [
            "string",
            "number",
            "integer",
            "boolean",
            "null"
          ]
        }
      }
    }
  }
}
